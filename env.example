# ─── GoHighLevel Credentials ─────────────────────────────────────────────────
# Get these from GHL Settings → Private Integrations
GHL_API_KEY=your_pit_token_here
GHL_LOCATION_ID=your_location_id_here

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3000

# Transport mode:
# 'sse'   = hosted server, accessible via URL (for Claude.ai MCP connector)
# 'stdio' = local mode for Claude Code / terminal
MCP_TRANSPORT=sse
